{% css %}
{% include "../assets/css/button.css" %}
{% include "../assets/css/mobile-menu.css" %}
{% include "../assets/css/header.css" %}
{% endcss %}


<header data-layer="header" class="header section">
  <a data-layer="logotype" href="{{ "/" | locale_url }}" class="logotype">
    <img eleventy:formats="webp" src="./assets/img/logotype.png" alt="Queer Varna" class="logotype__img" />
  </a>

<input type="checkbox" id="menu-toggle" class="menu-toggle-input">
  
  <label for="menu-toggle" class="burger-btn">
    <i class="burger-line"></i>
    <i class="burger-line"></i>
    <i class="burger-line"></i>
  </label>

{% macro renderNavListItem(entry) %}
{% set itemClass = "" %}
{% if entry.style == "primary" %}{% set itemClass = "button" %}{% endif %}
{% if entry.style == "secondary" %}{% set itemClass = "button button-secondary" %}{% endif %}

<li class="main-menu__item {% if entry.children.length %} has-children {% endif %}">
  {% if entry.children.length %}
    <input type="checkbox" id="sub{{ entry.order }}" class="submenu-toggle-input">
  {% endif %}

  <div class="menu-item-wrapper">
    <a href="{{ entry.url }}">{{ entry.title }}</a>
    {% if entry.children.length %}
      <label for="sub{{ entry.order }}" class="arrow" aria-label="Toggle submenu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" style="pointer-events: none;">
          <path d="M20.625 8.25L11 16.5L1.375 8.25" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </label>
    {% endif %}
  </div>

  {% if entry.children.length %}
    <ul class="sub-menu">
      {% for child in entry.children %}
        <li class="main-menu__item">
          <a href="{{ child.url }}">{{ child.title }}</a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</li>
{% endmacro %}

{% set navPages = collections.all | eleventyNavigation %}

<nav class="main-menu">
  <ul class="main-menu__list">
    {%- for entry in navPages %}
      {% set showItem = false %}
      {% if not lang or entry.url.startsWith("/" + lang + "/") or (lang == "bg" and not (entry.url.startsWith("/en/") or entry.url.startsWith("/ru/"))) %}
        {% set showItem = true %}
      {% endif %}

      {% if showItem %}
        {{ renderNavListItem(entry) }}
      {% endif %}
    {%- endfor -%}
  </ul>
</nav>
  
